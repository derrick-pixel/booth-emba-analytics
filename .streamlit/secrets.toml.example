# Copy this file to .streamlit/secrets.toml for local dev.
# On Streamlit Cloud, paste the [access_codes] section into:
#   App settings → Secrets
#
# Keys are labels (who owns the code), values are the actual codes users type.
# Delete a line here (or in the Streamlit Cloud dashboard) to revoke that person.

[access_codes]
owner = "change-me-to-something-long"
chris = "chris-ma-2026-abc"
recruiter_example = "bain-xyz-42"
